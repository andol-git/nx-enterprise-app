// Prisma Client Generator
generator client {
  provider = "prisma-client-js"
}

// Database connection
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================
// 👤 User Model (Auth)
// =========================
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =========================
// 🔐 Roles (Authorization)
// =========================
enum Role {
  USER
  ADMIN
}